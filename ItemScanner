-- ─── PRESTIGE / LEVEL HELPERS ────────────────────────────────────────────────

-- Roman numeral → integer (handles I through X = 1..10)
local ROMAN_MAP = {
    I=1, II=2, III=3, IV=4, V=5,
    VI=6, VII=7, VIII=8, IX=9, X=10,
}
local function romanToInt(s)
    return ROMAN_MAP[s and s:upper():match("^%s*(.-)%s*$")] or 0
end

-- Returns a single comparable score: prestige * 100 + level
-- Reads directly from the leaderboard container (instant, no profile open).
local function getPlayerScore(username)
    local ok, levelLabel = pcall(function()
        return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Container[username].Level.Level
    end)
    local level = 0
    if ok and levelLabel then
        level = tonumber(levelLabel.Text) or 0
    end

    local ok2, prestigeLabel = pcall(function()
        return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Container[username].Level.Prestige
    end)
    local prestige = 0
    if ok2 and prestigeLabel then
        prestige = romanToInt(prestigeLabel.Text)
    end

    return prestige * 100 + level
end

-- ─── RARITY / COLOUR HELPERS ─────────────────────────────────────────────────

local function colorClose(a, b, threshold)
    threshold = threshold or 10
    return math.abs(a.R*255 - b.R*255) <= threshold
        and math.abs(a.G*255 - b.G*255) <= threshold
        and math.abs(a.B*255 - b.B*255) <= threshold
end

local function getRarity(newItem)
    local itemNameFrame = newItem:FindFirstChild("ItemName")
    if not itemNameFrame then return 99, "UNKNOWN" end
    local bg = itemNameFrame.BackgroundColor3
    for _, r in ipairs(RARITY_ORDER) do
        if colorClose(bg, r.color) then
            return r.rank, r.name
        end
    end
    return 99, "UNKNOWN"
end

