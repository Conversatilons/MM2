local function hasAnyNewItem(itemsContainer)
    for _, categoryFrame in ipairs(itemsContainer:GetChildren()) do
        if not categoryFrame:IsA("ScrollingFrame") then continue end
        local innerContainer = categoryFrame:FindFirstChild("Container")
        if innerContainer then
            for _, obj in ipairs(innerContainer:GetChildren()) do
                if obj.Name == "NewItem" then return true end
            end
        end
    end
    return false
end

-- ─── HIDE INSPECT PANEL EVERY FRAME DURING SCAN ─────────────────────────────
-- Firing buttons on hidden ancestors doesn't work, but we can keep the Inspect
-- panel rendered off-screen (Y +3000) and force every child invisible so the
-- player never sees it, while our getconnections/Fire() calls still go through
-- because the Inspect frame itself remains Visible = true.

local RunService = game:GetService("RunService")

-- Grab all the nodes we want to hide / move. Using pcall so a missing node
-- never crashes the script.
local function safeGet(path)
    local ok, v = pcall(function() return path() end)
    return ok and v or nil
end

local Inspect     = safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect end)
local ViewProfile = safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.ViewProfile end)

-- Nodes forced Visible=false every RenderStep during the scan.
-- Inspect itself stays Visible=true (needed for button fires) but is shunted
-- off-screen. ViewProfile is kept hidden throughout and left hidden when done
-- so the game's own toggle can open it again normally.
local hideEveryFrame = {
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Close.TextLabel end),
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Container.Username end),
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Close end),
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Container.Trade.TextLabel end),
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Container.Trade end),
    safeGet(function() return LocalPlayer.PlayerGui.MainGUI.Game.Leaderboard.Inspect.Container end),
}

-- Store the original Inspect position so we can restore it at the end.
local inspectOriginalPos = Inspect and Inspect.Position or UDim2.new(0, 0, 0, 0)

-- Shunt Inspect way off-screen (+3 on Y axis in offset = 3 pixels, but the
-- request is Y+3 scale units which puts it 3 screen-heights below the visible
-- area — using Scale so it works at any resolution).
if Inspect then
    Inspect.Position = UDim2.new(
        inspectOriginalPos.X.Scale,
        inspectOriginalPos.X.Offset,
        inspectOriginalPos.Y.Scale + 3,
        inspectOriginalPos.Y.Offset
    )
end


local function shuntOffScreen(guiObject, yScaleOffset)
	if not guiObject then return end

	-- store original position ON the object
	if not guiObject:GetAttribute("OriginalPosX") then
		guiObject:SetAttribute("OriginalPosX", guiObject.Position.X.Scale)
		guiObject:SetAttribute("OriginalPosXOffset", guiObject.Position.X.Offset)
		guiObject:SetAttribute("OriginalPosY", guiObject.Position.Y.Scale)
		guiObject:SetAttribute("OriginalPosYOffset", guiObject.Position.Y.Offset)
	end

	guiObject.Position = UDim2.new(
		guiObject.Position.X.Scale,
		guiObject.Position.X.Offset,
		guiObject.Position.Y.Scale + (yScaleOffset or 3),
		guiObject.Position.Y.Offset
	)
end

local function restore(guiObject)
	if not guiObject then return end

	guiObject.Position = UDim2.new(
		guiObject:GetAttribute("OriginalPosX"),
		guiObject:GetAttribute("OriginalPosXOffset"),
		guiObject:GetAttribute("OriginalPosY"),
		guiObject:GetAttribute("OriginalPosYOffset")
	)
end




