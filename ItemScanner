local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function getContainer()
	return LocalPlayer.PlayerGui
		:WaitForChild("MainGUI")
		:WaitForChild("Game")
		:WaitForChild("ViewProfile")
		:WaitForChild("Main")
		:WaitForChild("Weapons")
		:WaitForChild("Items")
		:WaitForChild("Container")
end

local function cloneItems()
	local clones = {}

	local container = getContainer()
	if not container then
		warn("Container not found")
		return clones
	end

	-- deep search EVERYTHING under container
	for _, obj in ipairs(container:GetDescendants()) do
		if obj.Name == "NewItem" then
			local rank, rarityName = getRarity(obj)

			table.insert(clones, {
				frame = obj:Clone(),
				rank = rank,
				rarityName = rarityName
			})
		end
	end

	return clones
end

local function cloneExtraInfo()
    local info = {}
    local okE, elite = pcall(function()
        return LocalPlayer.PlayerGui.MainGUI.Game.ViewProfile.Main.Profile.Container.Character.Elite
