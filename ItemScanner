    if okL and levelFrame then info.levelFrame = levelFrame:Clone() end

    local okS, statsContainer = pcall(function()
        return LocalPlayer.PlayerGui.MainGUI.Game.ViewProfile.Main.Profile.Container.Profile.Season1Stats.Container
    end)
    if okS and statsContainer then info.rawStatsContainer = statsContainer end

