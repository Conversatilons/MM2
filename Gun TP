-- VibeCoded GunTP, WILL add gui later, right alt to tp to gun, does have a highlight and noti when the gun is available.

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

local currentGun
local highlight
local notifiedFound = false

local function notify(text)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = "Gun Finder",
			Text = text,
			Duration = 3
		})
	end)
end

local function updateGun()
	local foundGun = nil

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == "GunDrop" then
			foundGun = obj
			break
		end
	end

	-- Gun found
	if foundGun then
		currentGun = foundGun

		if not highlight or highlight.Adornee ~= foundGun then
			if highlight then
				highlight:Destroy()
			end

			highlight = Instance.new("Highlight")
			highlight.Name = "GunDropHighlight"
			highlight.FillTransparency = 1
			highlight.OutlineTransparency = 0
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.Adornee = foundGun
			highlight.Parent = foundGun
		end

		if not notifiedFound then
			notifiedFound = true
			notify("Gun Found ✅")
		end
	else
		currentGun = nil

		if highlight then
			highlight:Destroy()
			highlight = nil
		end

		notifiedFound = false
	end
end

-- Continuous scanner
task.spawn(function()
	while true do
		updateGun()
		task.wait(0.5)
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if input.KeyCode == Enum.KeyCode.LeftAlt then
		if not currentGun or not currentGun.Parent then
			notify("No gun found")
			return
		end

		local character = LocalPlayer.Character
		if not character then
			return
		end

		local hrp = character:FindFirstChild("HumanoidRootPart")
		if not hrp then
			return
		end

		local oldCFrame = hrp.CFrame

		hrp.CFrame = currentGun.CFrame + Vector3.new(0, 3, 0)
		task.wait(0.2)
		hrp.CFrame = oldCFrame
	end
end)
